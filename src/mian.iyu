<event><eventItme type="clicki">t()
{
	ug(13,"text",sss.cmd)
	call(结果,"mjava","shellExec.execShell",sss.cmd)
	syso(结果)
    //us(17,"text",结果)
	ufnsui()
	{
		ug(8,"text",原先)
		f(sss.cmd == "")
		{
			us(8,"text",原先 + "\nYou haven't entered anything.\n")
		}
        else f(sss.cmd == "Chaos Miau!")
        {
        	tw("Miau 🐱!")
        }
        else f(sss.cmd == "i like u")
        {
        	tw("youtube.com")
        }
        else
        {
		us(8,"text",原先 + "\n&gt; " + sss.cmd)
		ug(8,"text",原先)
		us(8,"text",原先 + "\n" + 结果)
		ug(8,"text",原先)
        }
		
		f(结果 ? "[2J[H")
		{
			us(8,"text", "")
			syso(sss.cmd)
		}
		else
		{
			syso(sss.cmd)
		}
	}
}</eventItme></event>
